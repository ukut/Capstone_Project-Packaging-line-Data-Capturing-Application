# Application
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-this-is-only-for-dev
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=sqlite:///./bottling.db

# Session
SESSION_LIFETIME_MINUTES=480
SESSION_COOKIE_NAME=bottling_session
SESSION_COOKIE_SECURE=false   # true in production (HTTPS)

# Anomaly thresholds (configurable, not hardcoded)
ANOMALY_DOWNTIME_MINUTES_THRESHOLD=30
ANOMALY_REJECT_RATE_PERCENT_THRESHOLD=2.0
